FMP_API_KEY=your_fmp_api_key_here

# FRED API key — free from https://fred.stlouisfed.org/docs/api/api_key.html
# Required for full yield curve (DGS2 = 2Y yield, needed for 10Y-2Y spread in M17).
# Without it, YIELD_CURVE returns partial data (10Y/30Y/3M only, no 2Y spread).
FRED_API_KEY=your_fred_api_key_here

# Optional overrides
# ADVISOR_FRAMEWORK_PATH=/custom/path/to/framework/folder
# GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service_account.json
# GOOGLE_OAUTH_TOKEN=/path/to/token.json
# ADVISOR_LOG_LEVEL=INFO
